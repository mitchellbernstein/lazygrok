{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'LazyGrok v0.3: /ulw /brainstorm /debug /hyperplan /frontend /programming /visual-qa /ast-grep /teammode /sessions + full OmO skill set'",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT:-.}/scripts/prompt-mode-hint.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "search_replace|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'LazyGrok: after edits, apply comment-checker (no AI-slop comments).'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
