{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'LazyGrok: /ulw \u00b7 /ulw-plan \u00b7 /brainstorm \u00b7 /debug \u00b7 /hyperplan \u00b7 /start-work \u00b7 /ulw-loop \u00b7 /review-work'",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT:-.}/scripts/prompt-mode-hint.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "search_replace|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'LazyGrok: after edits, apply comment-checker (no AI-slop comments).'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
