{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"LazyGrok: prefer /lg-* commands (e.g. /lg-ulw /lg-brainstorm /lg-debug /lg-ulw-plan /lg-start-work). Bare /ulw etc. still work.\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${GROK_PLUGIN_ROOT:-.}/scripts/prompt-mode-hint.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "search_replace|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'LazyGrok: after edits, apply comment-checker (no AI-slop comments).'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
